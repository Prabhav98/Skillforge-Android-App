<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cream">

    <!-- Video Player Header -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/player_height">

        <ImageView
            android:id="@+id/iv_player_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Player background" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/player_gradient" />

        <!-- Top buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:paddingTop="36dp">

            <FrameLayout
                android:id="@+id/btn_back"
                android:layout_width="@dimen/circle_btn"
                android:layout_height="@dimen/circle_btn"
                android:background="@drawable/bg_circle_semi_white"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="@dimen/icon_medium"
                    android:layout_height="@dimen/icon_medium"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_arrow_back"
                    android:tint="@color/text_primary"
                    tools:ignore="UseAppTint" />
            </FrameLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <FrameLayout
                android:layout_width="@dimen/circle_btn"
                android:layout_height="@dimen/circle_btn"
                android:background="@drawable/bg_circle_semi_black">

                <ImageView
                    android:layout_width="@dimen/icon_medium"
                    android:layout_height="@dimen/icon_medium"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_fullscreen"
                    android:tint="@color/white"
                    tools:ignore="UseAppTint" />
            </FrameLayout>
        </LinearLayout>

        <!-- Center play button -->
        <FrameLayout
            android:layout_width="@dimen/play_btn_large"
            android:layout_height="@dimen/play_btn_large"
            android:layout_gravity="center"
            android:background="@drawable/bg_gray_circle">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play_arrow"
                android:tint="@color/text_primary"
                tools:ignore="UseAppTint" />
        </FrameLayout>

        <!-- Progress bar bottom -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_current_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="02:14"
                android:textColor="@color/white"
                android:textSize="@dimen/text_body_sm"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/progress_player"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                style="?android:attr/progressBarStyleHorizontal"
                android:progress="37"
                android:max="100"
                android:progressDrawable="@drawable/bg_progress_track" />

            <TextView
                android:id="@+id/tv_total_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="06:00"
                android:textColor="@color/white"
                android:textSize="@dimen/text_body_sm" />
        </LinearLayout>
    </FrameLayout>

    <!-- Lesson Info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp">

        <TextView
            android:id="@+id/tv_lesson_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/teal"
            android:textSize="@dimen/text_sm"
            android:textStyle="bold"
            tools:text="LESSON 1 · KOTLIN FUNDAMENTALS" />

        <TextView
            android:id="@+id/tv_lesson_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="@dimen/text_headline"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            tools:text="Welcome &amp; Setup" />

        <TextView
            android:id="@+id/tv_lesson_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="@dimen/text_body_md"
            android:textColor="@color/text_secondary"
            tools:text="Set up Android Studio and run your first Kotlin file." />
    </LinearLayout>

    <!-- Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginEnd="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lessons_tab"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body_md" />

            <View
                android:layout_width="28dp"
                android:layout_height="2dp"
                android:layout_marginTop="4dp"
                android:background="@color/teal" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="24dp"
            android:text="@string/notes_tab"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_body_md"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/resources_tab"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_body_md"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Lessons List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_lessons"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="20dp"
        android:paddingTop="4dp"
        android:clipToPadding="false"
        tools:listitem="@layout/item_lesson_player" />

</LinearLayout>