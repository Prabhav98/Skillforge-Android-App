<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/category_width"
    android:layout_height="@dimen/category_height"
    android:layout_marginEnd="12dp"
    app:cardCornerRadius="@dimen/corner_xl"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="14dp">

        <FrameLayout
            android:id="@+id/dot_bg"
            android:layout_width="@dimen/dot_bg_size"
            android:layout_height="@dimen/dot_bg_size"
            android:background="@drawable/bg_category_teal">

            <View
                android:id="@+id/dot"
                android:layout_width="@dimen/dot_size"
                android:layout_height="@dimen/dot_size"
                android:layout_gravity="center"
                android:background="@drawable/bg_dot_teal" />
        </FrameLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tv_category_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_normal"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_course_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_body_sm" />
    </LinearLayout>
</androidx.cardview.widget.CardView>